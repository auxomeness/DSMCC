{
  "name": "deca-sentrio",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the DECA Sentrio backend and frontend applications.",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:validate": "npm --prefix backend run prisma:validate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate",
    "prisma:seed": "npm --prefix backend run prisma:seed"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "author": "Karl Austin Pavia",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
