generator client {
  provider      = "prisma-client-js"
  output        = "../../node_modules/.prisma/client"
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  TENANT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ConcernCategory {
  PLUMBING
  ELECTRICAL
  WATER
  CLEANING
  WASTE_MANAGEMENT
  FACILITY_MAINTENANCE
  ADMINISTRATIVE
  OTHER
}

enum ConcernStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  PENDING_TENANT_APPROVAL
  REOPENED
  CLOSED
}

enum ConcernVisibility {
  PUBLIC
  PRIVATE
}

enum AppointmentStatus {
  PENDING
  APPROVED
  DECLINED
  COMPLETED
  CANCELLED
}

enum FeedbackType {
  FEEDBACK
  SUGGESTION
}

enum NotificationType {
  ACCOUNT_APPROVAL
  CONCERN_ACCEPTED
  CONCERN_REJECTED
  CONCERN_ASSIGNED
  CONCERN_UPDATED
  CONCERN_RESOLVED
  CONCERN_CLOSED
  APPOINTMENT_APPROVED
  APPOINTMENT_DECLINED
  SYSTEM
}

model User {
  id           String     @id @default(uuid())
  firstName    String
  lastName     String
  email        String     @unique
  phoneNumber  String?
  password     String
  role         Role       @default(TENANT)
  status       UserStatus @default(PENDING)
  profileImage String?
  lastLoginAt  DateTime?

  building   String?
  floor      String?
  unitNumber String?

  staffProfile  Staff?
  concerns      Concern[]        @relation("TenantConcerns")
  concernVotes  ConcernVote[]
  histories     ConcernHistory[] @relation("ConcernHistoryActor")
  appointments  Appointment[]    @relation("TenantAppointments")
  notifications Notification[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([role, status, building, floor, unitNumber])
}

model Office {
  id              String  @id @default(uuid())
  name            String  @unique
  description     String?
  officeHours     String?
  officeStartTime String?
  officeEndTime   String?
  slotDurationMin Int     @default(60)
  isActive        Boolean @default(true)

  staff        Staff[]
  concerns     Concern[]
  appointments Appointment[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
}

model Staff {
  id             String  @id @default(uuid())
  userId         String  @unique
  officeId       String
  position       String
  specialization String?
  isOfficeHead   Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  office Office @relation(fields: [officeId], references: [id], onDelete: Restrict)

  assignedConcerns Concern[] @relation("AssignedConcerns")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([officeId])
  @@index([officeId, isOfficeHead])
}

model Concern {
  id                  String            @id @default(uuid())
  concernNumber       String            @unique
  title               String
  category            ConcernCategory
  description         String
  building            String
  floor               String
  unitNumber          String
  locationDescription String
  preferredSchedule   DateTime
  imageUrl            String?
  status              ConcernStatus     @default(SUBMITTED)
  visibility          ConcernVisibility @default(PRIVATE)

  tenantId        String
  officeId        String
  assignedStaffId String?

  submittedAt DateTime  @default(now())
  acceptedAt  DateTime?
  assignedAt  DateTime?
  startedAt   DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?

  tenant        User             @relation("TenantConcerns", fields: [tenantId], references: [id], onDelete: Restrict)
  office        Office           @relation(fields: [officeId], references: [id], onDelete: Restrict)
  assignedStaff Staff?           @relation("AssignedConcerns", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  histories     ConcernHistory[]
  votes         ConcernVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([visibility])
  @@index([category])
  @@index([tenantId])
  @@index([officeId])
  @@index([assignedStaffId])
  @@index([createdAt])
  @@index([building, floor, unitNumber])
}

model ConcernVote {
  id        String @id @default(uuid())
  concernId String
  tenantId  String

  concern Concern @relation(fields: [concernId], references: [id], onDelete: Cascade)
  tenant  User    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([concernId, tenantId])
  @@index([concernId])
  @@index([tenantId])
}

model ConcernHistory {
  id        String         @id @default(uuid())
  concernId String
  userId    String
  action    String
  oldStatus ConcernStatus?
  newStatus ConcernStatus?
  remarks   String?

  concern Concern @relation(fields: [concernId], references: [id], onDelete: Restrict)
  actor   User    @relation("ConcernHistoryActor", fields: [userId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([concernId])
  @@index([userId])
  @@index([createdAt])
}

model Appointment {
  id          String            @id @default(uuid())
  tenantId    String
  officeId    String
  scheduledAt DateTime
  purpose     String
  status      AppointmentStatus @default(PENDING)
  remarks     String?

  tenant User   @relation("TenantAppointments", fields: [tenantId], references: [id], onDelete: Restrict)
  office Office @relation(fields: [officeId], references: [id], onDelete: Restrict)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([officeId])
  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
}

model Notification {
  id      String           @id @default(uuid())
  userId  String
  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([userId, isRead])
}

model Feedback {
  id      String       @id @default(uuid())
  name    String?
  email   String?
  type    FeedbackType
  message String

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@index([createdAt])
}
